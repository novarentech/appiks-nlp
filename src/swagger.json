{
  "openapi": "3.0.0",
  "info": {
    "title": "APPIKS NLP Mental Distress Classifier API",
    "description": "API for detecting and classifying levels of mental distress and crisis risk in Indonesian text.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-APPIKS-NLP-KEY"
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/api/analyze": {
      "post": {
        "summary": "Analyze text distress level",
        "description": "Analyze Indonesian text using the 3-layer weighted scoring classifier.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "text"
                ],
                "properties": {
                  "text": {
                    "type": "string",
                    "example": "Aku merasa sangat kesepian dan kosong"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful analysis",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "zone_status": {
                      "type": "string",
                      "example": "Yellow Zone"
                    },
                    "total_score": {
                      "type": "integer",
                      "example": 4
                    },
                    "matched_keywords": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "stem": {
                            "type": "string",
                            "example": "kosong"
                          },
                          "weight": {
                            "type": "integer",
                            "example": 4
                          },
                          "zone": {
                            "type": "string",
                            "example": "Yellow"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid input data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Missing 'text' field in request body."
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication failure",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "API Key is missing."
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "An internal error occurred while processing the request."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Check API health",
        "description": "Check if the API service is up and running.",
        "security": [],
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "healthy"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}